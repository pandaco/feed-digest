# ==============================================================================
# INOREADER-DIGEST: ENVIRONMENT VARIABLES CONFIGURATION
# ==============================================================================

# --- ADAPTER SELECTION ---
# SCRAPER_SOURCE: Comma-separated list of Inoreader streams to fetch
#   Values: 'inoreader' (unread items), 'inoreader-saved' (starred items)
#   Example: SCRAPER_SOURCE=inoreader,inoreader-saved
SCRAPER_SOURCE=inoreader-saved

# STORAGE_BACKEND: Choose your primary database
#   Values: 'google-sheets', 'notion', 'dynamodb'
STORAGE_BACKEND=google-sheets

# --- LLM PROVIDER CONFIGURATION ---
# LLM_PROVIDER: Sets which service to use for enrichment/summarization
#   Values: 'claude', 'gemini'
LLM_PROVIDER=claude

# ANTHROPIC (Claude): Requires LLM_PROVIDER=claude
#   Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-3-5-sonnet-20240620

# GOOGLE (Gemini): Requires LLM_PROVIDER=gemini
#   Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyAxxx
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# --- INOREADER CONFIGURATION ---
INOREADER_EMAIL=your_email@example.com
INOREADER_PASSWORD=your_password

# --- STORAGE CONFIGURATION (Required based on STORAGE_BACKEND) ---

# [IF STORAGE_BACKEND=notion]
# 1. Create integration: https://www.notion.so/my-integrations
# 2. Required DBs: Inbox, All, Saved (must include Title, Article ID, etc.)
NOTION_API_KEY=ntn_xxx
NOTION_INBOX_DB_ID=your_inbox_database_id
NOTION_ALL_DB_ID=your_all_database_id
NOTION_SAVED_DB_ID=your_saved_database_id

# [IF STORAGE_BACKEND=google-sheets]
# 1. Create Service Account (GCP Console), download JSON key.
# 2. Copy entire JSON file content onto ONE LINE.
GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}
# 3. Share the Google Sheet with the client_email from the JSON.
GOOGLE_SHEET_ID=1_xxx_your_sheet_id_xxx

# [IF STORAGE_BACKEND=dynamodb]
# AWS region of your DynamoDB tables
AWS_REGION=eu-central-1
# For local testing, set to http://localhost:8000. Leave blank for real AWS.
DYNAMODB_ENDPOINT=
# Table names (must be created in your AWS account before running)
DYNAMODB_TABLE_NAME=XXX
DYNAMODB_ARTICLES_TABLE_NAME=XXX
DYNAMODB_TAG_PREF_TABLE_NAME=XXX

# --- TELEGRAM BOT CONFIGURATION ---
# BotFather: Get TOKEN. UserInfoBot: Get personal CHAT_ID.
TELEGRAM_BOT_TOKEN=12345678:ABCDefGhIjKlMnOpQrStUvWxYz
TELEGRAM_CHAT_ID=123456789
TELEGRAM_SECRET_TOKEN=a_very_long_random_secret_string

# --- APP SETTINGS ---
NODE_ENV=development
SUMMARY_LANG=fr
ARTICLES_LIMIT=5
MAX_TAGS=3
DATE_FORMAT=yyyy-MM-dd HH:mm
SHOW_BROWSER=false
RUN_NOW=false

# --- PIPELINE & PERFORMANCE ---
PIPELINE_CONCURRENCY=5
PIPELINE_MIN_DELAY_MS=1000
PIPELINE_MAX_DELAY_MS=3000

# --- TAG PREFERENCE LEARNING ---
TAG_PREFERENCE_THRESHOLD=0.6
TAG_PREFERENCE_MIN_RUNS=3
RETENTION_DAYS_ALL=30

# --- USER INTERESTS ---
# Free-text description for LLM relevance scoring (e.g., "AI, web dev, security")
USER_INTERESTS=

# --- DASHBOARD API ---
API_PORT=3333
