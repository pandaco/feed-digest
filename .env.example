# ==============================================================================
#  feed-digest — environment variables
# ==============================================================================
#  Every key listed here is read by the code. Anything missing here is unused.
#  Copy to `.env`, fill in the sections relevant to your STORAGE_BACKEND and
#  LLM_PROVIDER. See DEVELOPMENT.md for end-to-end local dev recipes, and
#  SETUP_GUIDE.md for how to obtain each third-party credential.
# ==============================================================================

# ------------------------------------------------------------------------------
#  Pipeline selection
# ------------------------------------------------------------------------------

# Inoreader streams to fetch (comma-separated)
#   inoreader        unread items
#   inoreader-saved  starred items
SCRAPER_SOURCE=inoreader

# Article persistence backend
#   google-sheets | notion | dynamodb
STORAGE_BACKEND=notion

# LLM backend used for enrichment (summary, tags, relevance score)
#   claude | gemini | ollama
LLM_PROVIDER=ollama

# ------------------------------------------------------------------------------
#  LLM credentials (only the section matching LLM_PROVIDER is required)
# ------------------------------------------------------------------------------

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-3-5-sonnet-20240620

# Google Gemini — https://aistudio.google.com/app/apikey  (free tier available)
GEMINI_API_KEY=AIzaSyAxxx
GEMINI_MODEL=gemini-1.5-flash

# Ollama (local) — https://ollama.com/download  then `ollama pull llama3.1:8b`
# No API key needed. Defaults shown below.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Safety cap on generated tokens (the JSON schema usually stops the model
# around 100–150 tokens). Drop lower if you ever see runaway responses.
OLLAMA_NUM_PREDICT=512
# Context window. Models default to 131k tokens which forces Ollama to
# reserve large amounts of VRAM for nothing — typical prompt here is
# ~1500 tokens. 4096 leaves headroom and speeds up inference.
OLLAMA_NUM_CTX=4096

# ------------------------------------------------------------------------------
#  Inoreader credentials (required)
# ------------------------------------------------------------------------------
INOREADER_EMAIL=you@example.com
INOREADER_PASSWORD=your_password

# ------------------------------------------------------------------------------
#  Storage credentials (only the section matching STORAGE_BACKEND is required)
# ------------------------------------------------------------------------------

# [STORAGE_BACKEND=notion]
# 1. Create an integration at https://www.notion.so/my-integrations
# 2. Create 3 databases (Inbox, All, Saved) and share each with the integration
# 3. `npm run setup` provisions the schema automatically
NOTION_API_KEY=ntn_xxx
NOTION_INBOX_DB_ID=your_inbox_database_id
NOTION_ALL_DB_ID=your_all_database_id
NOTION_SAVED_DB_ID=your_saved_database_id

# [STORAGE_BACKEND=google-sheets]
# 1. Create a service account in Google Cloud, enable Sheets API, download JSON
# 2. Copy the entire JSON onto ONE LINE here
# 3. Share the spreadsheet with the service account's client_email (Editor)
# 4. `npm run setup` creates the required tabs and headers
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_SHEET_ID=1_xxx_your_sheet_id_xxx

# [STORAGE_BACKEND=dynamodb]
# Real AWS: leave DYNAMODB_ENDPOINT empty, set AWS_ACCESS_KEY_ID/SECRET in env
# Local:   `docker run -p 8000:8000 amazon/dynamodb-local`, then:
#            DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=eu-central-1
DYNAMODB_ENDPOINT=
DYNAMODB_ARTICLES_TABLE_NAME=feed-digest-articles

# ------------------------------------------------------------------------------
#  Tag preference learning
# ------------------------------------------------------------------------------
# When DYNAMODB_TAG_PREF_TABLE_NAME is set, prefs go to DynamoDB.
# When empty, prefs go to `tag-preferences.json` at the project root (recommended
# for local dev — no AWS required).
DYNAMODB_TAG_PREF_TABLE_NAME=
TAG_PREFERENCE_THRESHOLD=0.6
TAG_PREFERENCE_MIN_RUNS=3

# ------------------------------------------------------------------------------
#  Telegram (run summary notifications + dashboard API token)
# ------------------------------------------------------------------------------
# Token from @BotFather, chat ID from @userinfobot. See SETUP_GUIDE.md.
TELEGRAM_BOT_TOKEN=12345678:ABCDefGhIjKlMnOpQrStUvWxYz
TELEGRAM_CHAT_ID=123456789
# Shared secret required on every dashboard API request (header
# `x-telegram-bot-api-secret-token`). Leave empty in local dev to disable auth.
TELEGRAM_SECRET_TOKEN=

# ------------------------------------------------------------------------------
#  Pipeline tuning
# ------------------------------------------------------------------------------
SUMMARY_LANG=fr             # fr | en — language of summaries and tags
ARTICLES_LIMIT=50           # max articles per run
MAX_TAGS=3                  # max tags per enriched article
PIPELINE_CONCURRENCY=5      # parallel enrichments
PIPELINE_MIN_DELAY_MS=1000  # jitter between LLM calls (cloud rate-limit friendly,
PIPELINE_MAX_DELAY_MS=3000  #   automatically skipped when LLM_PROVIDER=ollama)
ENRICH_CONTENT_MAX_CHARS=4000 # truncate article body before sending to the LLM.
                            #   4000 chars is enough for a 3–5 sentence summary
                            #   and keeps Ollama's prompt_eval fast on long posts.
RETENTION_DAYS_ALL=30       # items older than N days are purged by `npm run purge`
SHOW_BROWSER=false          # true → run Playwright headed (debug login flow)
SKIP_MARK_AS_READ=false     # true → don't unread/unstar items on Inoreader after
                            #   processing (handy for local dev: re-run on the
                            #   same articles without re-starring them)

# ------------------------------------------------------------------------------
#  User profile & dashboard
# ------------------------------------------------------------------------------
# Free-text interest profile injected into the enrich prompt to drive the
# relevance score (1–10). Editable from the dashboard "Interests" tab; also
# persisted in `.user-interests.txt` at the project root.
USER_INTERESTS=

API_PORT=3333                          # NestJS API port (dashboard backend)
DATE_FORMAT=yyyy-MM-dd HH:mm           # dashboard date format
