# ==============================================================================
# INOREADER-DIGEST: ENVIRONMENT VARIABLES CONFIGURATION
# ==============================================================================

# --- INOREADER CONFIGURATION ---
# Login via https://www.inoreader.com/
INOREADER_EMAIL=your_email@example.com
INOREADER_PASSWORD=your_password

# --- LLM PROVIDER CONFIGURATION ---
# Choice: 'claude' or 'gemini'
LLM_PROVIDER=claude

# ANTHROPIC (Claude): Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx
# Optional: Specific model (default: claude-3-5-sonnet-20240620)
CLAUDE_MODEL=claude-3-5-sonnet-20240620

# GOOGLE (Gemini): Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyAxxx
# Optional: Specific model (default: gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-pro

# --- GOOGLE SHEETS CONFIGURATION (only if STORAGE_BACKEND=google-sheets) ---
# 1. Create a project at https://console.cloud.google.com/
# 2. Enable "Google Sheets API"
# 3. Create a "Service Account", then "Manage Keys" -> "Add Key" -> "JSON"
# 4. Copy the ENTIRE JSON content into this variable (it must be on ONE LINE)
# Tip: Use 'cat service-account.json | jq -c' to get it on one line if you have jq.
GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "...", ...}

# Google Sheet ID: Take it from your Spreadsheet URL
# Example: https://docs.google.com/spreadsheets/d/1_ABC_123_XYZ/edit -> ID is "1_ABC_123_XYZ"
# IMPORTANT: Share your sheet with the "client_email" found in your service-account.json!
GOOGLE_SHEET_ID=1_xxx_your_sheet_id_xxx

# --- TELEGRAM BOT CONFIGURATION ---
# 1. Message @BotFather on Telegram to create a bot and get the TOKEN
TELEGRAM_BOT_TOKEN=12345678:ABCDefGhIjKlMnOpQrStUvWxYz

# 2. Message @userinfobot to get your personal Chat ID (a number)
TELEGRAM_CHAT_ID=123456789

# 3. Webhook Secret: A random long string of your choice (for security)
TELEGRAM_SECRET_TOKEN=a_very_long_random_secret_string_of_your_choice

# --- ADAPTER SELECTION ---
# Scraper implementation to use (default: inoreader)
SCRAPER_SOURCE=inoreader
# Storage backend to use: 'google-sheets' or 'notion' (default: google-sheets)
STORAGE_BACKEND=google-sheets

# --- NOTION CONFIGURATION (only if STORAGE_BACKEND=notion) ---
# 1. Create an integration at https://www.notion.so/my-integrations
# 2. Create 3 databases (Inbox, All, Saved) with these properties:
#    - Title (title), ID (rich_text), Run At (rich_text), Published At (rich_text),
#      Source (rich_text), URL (url), Tags (rich_text), Summary (rich_text),
#      Importance (rich_text), Content Unavailable (checkbox),
#      LLM Provider (rich_text), Summary Language (rich_text)
# 3. Share each database with your integration
NOTION_API_KEY=ntn_xxx
NOTION_INBOX_DB_ID=your_inbox_database_id
NOTION_ALL_DB_ID=your_all_database_id
NOTION_SAVED_DB_ID=your_saved_database_id

# --- GENERAL APP SETTINGS ---
# Maximum number of articles to process per run (default: 150)
ARTICLES_LIMIT=5
# Maximum number of tags to generate per article (default: 3)
MAX_TAGS=3
# --- PERFORMANCE & CONCURRENCY ---
# Number of articles processed at the same time (default: 5). 
# Higher values increase throughput but raise the risk of LLM 429 (Rate Limit) errors.
PIPELINE_CONCURRENCY=5

# Base stagger delay in milliseconds (default: 1000). 
# Defines the RHYTHM: Task #N starts at (N * PIPELINE_MIN_DELAY_MS).
# Example: with 1000ms, article #1 starts at 0s, #2 at 1s, #3 at 2s...
PIPELINE_MIN_DELAY_MS=1000

# Maximum random jitter in milliseconds (default: 3000). 
# Defines the NOISE: Adds unpredictable extra delay to each task to avoid hitting APIs in a perfect, detectable rhythm.
# Formula: Total Wait = (Index * PIPELINE_MIN_DELAY_MS) + Random(0 to PIPELINE_MAX_DELAY_MS).
# Example: with min=1000 and max=3000, article #11 (index 10) starts between 10s (10*1000 + 0) and 13s (10*1000 + 3000).
PIPELINE_MAX_DELAY_MS=3000
# Language: 'fr' or 'en' (controls LLM output and Telegram messages)
SUMMARY_LANG=fr
# Set to 'development' to use file-based session instead of DynamoDB
NODE_ENV=development
# Set to 'true' to show the Playwright browser window (for debugging)
SHOW_BROWSER=false
# Set to 'true' to bypass the Paris time window guard (for local dev)
RUN_NOW=false
# Name of your DynamoDB table (e.g., 'feed-digest-sessions-prod')
DYNAMODB_TABLE_NAME=feed-digest-sessions-prod
# Name of the DynamoDB table for tag preferences (e.g., 'feed-digest-tag-prefs-prod')
DYNAMODB_TAG_PREF_TABLE_NAME=feed-digest-tag-prefs-prod
# AWS Region where your DynamoDB is located (default: eu-west-1)
AWS_REGION=eu-west-1

# --- TAG PREFERENCE LEARNING ---
# Score threshold above which a tag is auto-selected (0.0 to 1.0, default: 0.6)
TAG_PREFERENCE_THRESHOLD=0.6
# Minimum number of times a tag must be presented before auto-selection kicks in (default: 3)
TAG_PREFERENCE_MIN_RUNS=3
